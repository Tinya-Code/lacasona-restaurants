---
// ─── MobileMenuButton — Dumb Component ───────────────────────────────────────
// Responsabilidad única: renderizar el botón hamburguesa para móvil.
// El estado open/closed lo controla el Smart component vía JS cliente.

interface Props {
  /** ID del panel de menú que controla (para aria-controls) */
  controls: string;
  /** Etiqueta accesible */
  ariaLabel?: string;
}

const {
  controls,
  ariaLabel = "Abrir menú de navegación",
} = Astro.props;
---

<button
  id="mobile-menu-btn"
  type="button"
  aria-controls={controls}
  aria-expanded="false"
  aria-label={ariaLabel}
  class="relative flex h-10 w-10 flex-col items-center justify-center gap-[5px] rounded-lg transition-colors duration-200 hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] lg:hidden"
>
  <!-- Línea 1 -->
  <span
    id="burger-line-1"
    class="h-0.5 w-6 rounded-full bg-white transition-all duration-300 origin-center"
  ></span>
  <!-- Línea 2 -->
  <span
    id="burger-line-2"
    class="h-0.5 w-6 rounded-full bg-white transition-all duration-300"
  ></span>
  <!-- Línea 3 -->
  <span
    id="burger-line-3"
    class="h-0.5 w-6 rounded-full bg-white transition-all duration-300 origin-center"
  ></span>
</button>

<script>
  const btn = document.getElementById("mobile-menu-btn")!;
  const line1 = document.getElementById("burger-line-1")!;
  const line2 = document.getElementById("burger-line-2")!;
  const line3 = document.getElementById("burger-line-3")!;

  let isOpen = false;

  btn.addEventListener("click", () => {
    isOpen = !isOpen;
    btn.setAttribute("aria-expanded", String(isOpen));
    btn.setAttribute(
      "aria-label",
      isOpen ? "Cerrar menú de navegación" : "Abrir menú de navegación"
    );

    // Animación hamburguesa → X
    if (isOpen) {
      line1.classList.add("translate-y-[7px]", "rotate-45");
      line2.classList.add("opacity-0", "scale-x-0");
      line3.classList.add("-translate-y-[7px]", "-rotate-45");
    } else {
      line1.classList.remove("translate-y-[7px]", "rotate-45");
      line2.classList.remove("opacity-0", "scale-x-0");
      line3.classList.remove("-translate-y-[7px]", "-rotate-45");
    }

    // Emitir evento para que el Smart component reaccione
    window.dispatchEvent(
      new CustomEvent("toggle-mobile-menu", { detail: { open: isOpen } })
    );
  });
</script>
