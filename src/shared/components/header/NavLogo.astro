---
// ─── NavLogo — Dumb Component ─────────────────────────────────────────────────
// Responsabilidad única: renderizar el logo del sitio.
// No tiene lógica propia; recibe todo vía props.

interface Props {
  /** Texto principal del logo */
  name: string;
  className?: string;

  /** Ruta href del logo (vuelve al inicio) */
  href: string;

}

const { name, href, className } = Astro.props;
---

<a
  href={href}
  aria-label={`Ir al inicio — ${name}`}
  class:list={[
    "group  p-1 ring-8 ring-secondary bg-white rounded-full ",
    className,
  ]}
>
<img src="/logo-lacasona.svg" alt={name} class="h-14 w-14 p-1" />
</a>
