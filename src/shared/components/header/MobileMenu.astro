---
// ─── MobileMenu — Dumb Component ─────────────────────────────────────────────
// Responsabilidad única: renderizar el panel del menú móvil.
// Recibe los links y el CTA vía props; el estado open/close lo gestiona el Smart.

import NavLinks from "./NavLinks.astro";

import type { NavLink } from "./NavLinks.astro";

interface Props {
  id: string;
  links: NavLink[];
  cta: {
    label: string;
    href: string;
  };
}

const { id, links, cta } = Astro.props;
---

<div
  id={id}
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación móvil"
  class="fixed inset-0 z-40 flex flex-col bg-[var(--color-secondary)]/95 backdrop-blur-xl
         translate-x-full transition-transform duration-300 ease-in-out lg:hidden"
>
  <!-- Franja superior decorativa -->
  <div class="h-1 w-full bg-gradient-to-r from-[var(--color-accent)] via-[var(--color-primary)] to-[var(--color-accent)]">
  </div>

  <!-- Espaciado para el header fijo -->
  <div class="h-[72px] shrink-0"></div>

  <!-- Contenido del menú -->
  <div class="flex flex-1 flex-col justify-between px-6 py-8 overflow-y-auto">
    <!-- Links de navegación en vertical -->
    <NavLinks links={links} orientation="vertical" class="text-lg" />

    <!-- Separador -->
    <div class="my-6 h-px bg-white/10"></div>

    <!-- Footer del menú -->
    <p class="mt-8 text-center text-xs text-white/30 font-body">
      © {new Date().getFullYear()} La Casona Manchay
    </p>
  </div>
</div>

<!-- Overlay/backdrop -->
<div
  id="mobile-menu-overlay"
  aria-hidden="true"
  class="fixed inset-0 z-30 bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"
>
</div>

<script>
  const panel = document.getElementById("mobile-panel")!;
  const overlay = document.getElementById("mobile-menu-overlay")!;

  window.addEventListener("toggle-mobile-menu", ((e: Event) => {
    const { open } = (e as CustomEvent<{ open: boolean }>).detail;

    if (open) {
      panel.classList.remove("translate-x-full");
      overlay.classList.remove("opacity-0", "pointer-events-none");
      document.body.style.overflow = "hidden";
    } else {
      panel.classList.add("translate-x-full");
      overlay.classList.add("opacity-0", "pointer-events-none");
      document.body.style.overflow = "";
    }
  }) as EventListener);

  // Cerrar al hacer clic en el overlay
  overlay.addEventListener("click", () => {
    window.dispatchEvent(
      new CustomEvent("toggle-mobile-menu", { detail: { open: false } })
    );
    // Sincronizar el botón hamburguesa
    const btn = document.getElementById("mobile-menu-btn");
    if (btn) {
      btn.setAttribute("aria-expanded", "false");
      document.getElementById("burger-line-1")?.classList.remove("translate-y-[7px]", "rotate-45");
      document.getElementById("burger-line-2")?.classList.remove("opacity-0", "scale-x-0");
      document.getElementById("burger-line-3")?.classList.remove("-translate-y-[7px]", "-rotate-45");
    }
  });

  // Cerrar al presionar Escape
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      window.dispatchEvent(
        new CustomEvent("toggle-mobile-menu", { detail: { open: false } })
      );
    }
  });
</script>
