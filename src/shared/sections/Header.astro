---
import NavLogo from "../components/header/NavLogo.astro";
import NavLinks from "../components/header/NavLinks.astro";
import type { NavLink } from "../components/header/NavLinks.astro";
import { Icon } from "astro-icon/components";
// ─── Objeto de configuración del Header ──────────────────────────────────────
const HEADER_CONFIG = {
  /** Logo y marca */
  logo: {
    name: "La Casona",
    tagline: "Manchay · Lima",
    href: "/",
  },
  links: [
    { label: "Menú", href: "/menu-la-casona-manchay" },
    { label: "Galeria", href: "/info-restaurante" },
  ] satisfies NavLink[],

} as const;

// ─── Props (para personalización por instancia) ───────────────────────────────
interface Props {
  links?: NavLink[];
  class?: string;
}

const { links = HEADER_CONFIG.links, class: extraClass = "" } = Astro.props;
---

<!-- ─── Header wrapper ─────────────────────────────────────────────────────── -->
<header
  id="site-header"
  class:list={[
    "fixed top-4 h-12  z-50 w-full",
    "transition-all duration-300 ease-in-out",
    extraClass,
  ]}
>
  <!-- Fondo con glassmorphism (visible al hacer scroll) -->
  <div
    id="header-backdrop"
    class="absolute inset-0 grid grid-cols-3 items-center bg-primary mx-2 rounded-full backdrop-blur-0 border-b border-white/0 transition-all duration-300 px-4"
  >
    <!-- Grupo izquierdo -->
    <div
      class="flex items-center md:justify-start lg:justify-center col-start-1 col-end-2 gap-4 w-full"
    >
      <a
        href="https://facebook.com/tuPagina"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Síguenos en Facebook"
        class="text-white/70 hover:text-white transition-all duration-200 hover:scale-110"
      >
        <Icon name="fa6-brands:facebook" class="w-6 h-6 md:w-7 md:h-7" />
      </a>

      <a
        href="https://instagram.com/tuUsuario"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Síguenos en Instagram"
        class="text-white/70 hover:text-white transition-all duration-200 hover:scale-110"
      >
        <Icon name="fa6-brands:instagram" class="w-6 h-6 md:w-7 md:h-7" />
      </a>
    </div>

    <!-- Columna central: espacio reservado para logo/título -->
    <div class="col-start-2 col-end-3"></div>

    <!-- Grupo derecho -->
    <div
      class="flex items-center justify-end lg:justify-center col-start-3 col-end-4 gap-4 w-full"
    >
      <a
        href="https://tiktok.com/@tuUsuario"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Síguenos en TikTok"
        class="text-white/70 hover:text-white transition-all duration-200 hover:scale-110"
      >
        <Icon name="simple-icons:tiktok" class="w-6 h-6 md:w-7 md:h-7" />
      </a>

      <a
        href="https://maps.google.com/?q=TuNegocio"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Cómo llegar en Google Maps"
        class="text-white/70 hover:text-white transition-all duration-200 hover:scale-110"
      >
        <Icon name="simple-icons:googlemaps" class="w-6 h-6 md:w-7 md:h-7" />
      </a>
    </div>
  </div>

  <!-- Contenido del header -->
  <div
    class="relative bg-secondary rounded-full h-full mx-auto max-w-lg px-4 sm:px-6 lg:px-8
           flex items-center justify-end md:justify-between"
  >
    <!-- LOGO — Dumb Component -->
    <NavLogo
      name={HEADER_CONFIG.logo.name}
      className="absolute left-1/2 -translate-x-1/2"
      href={HEADER_CONFIG.logo.href}
    />

    <!-- NAVEGACIÓN desktop — Dumb Component -->
    <NavLinks
      links={links}
      orientation="horizontal"
      class="w-full justify-around flex"
    />
  </div>
</header>