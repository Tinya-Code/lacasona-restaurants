---
import { Icon } from 'astro-icon/components';
interface Props {
  badge?: string;
  title?: string;
  highlight?: string;
  description?: string;
  location?: string;
  image?: string;
  imageAlt?: string;
  menuHref?: string;
  menuLabel?: string;
  promoHref?: string;
  promoLabel?: string;
}

const {
  badge = "Al carbón, como debe ser",
  title = "La Casona",
  highlight = "Restaurant",
  description = "Contamos con una gran variedad de platos: Pollo a la brasa, broaster, alitas y salchipapas preparados al momento. Bebidas naturales, cocteles de la casa y la sazón que Manchay ya conoce.",
  location = "Plaza Cívica de Manchay, frente al skate park",
  image = "/hero.webp",
  imageAlt = "Pollo a la brasa peruano servido con papas y ensalada",
  menuHref = "/menu-la-casona-manchay",
  menuLabel = "Ver Menú",
  promoHref = "#promociones",
  promoLabel = "Ver Promociones",
} = Astro.props;
---

<section class="relative flex flex-col justify-center items-center overflow-hidden min-h-[100svh] md:max-h-150 py-26 ">


  <div class="relative mx-auto flex flex-col md:flex-row justify-center space-y-4 items-center gap-4   ">
    <!-- Columna de texto -->
    <div class="flex-1  px-4 text-center lg:col-span-2 md:max-w-md lg:text-left">

      <h1 class="font-display mt-6 tracking-tighter drop-shadow-xs text-secondary-text text-5xl md:text-6xl lg:text-7xl ">
        {title}
        <span class="block text-secondary-text">{highlight}</span>
      </h1>

      <p class="mt-6 max-w-xl  font-bold text-secondary-text/80 lg:mx-0 mx-auto font-body">
        {description}
      </p>

      <div class="mt-5 flex items-start justify-center gap-0.5 font-display text-secondary/80 lg:justify-start">
        <Icon name="simple-icons:googlemaps" class="w-6 h-6  text-accent" />
        <span class="text-secondary-text">{location}</span>
      </div>

      <!-- Botones -->
      <div class="mt-9 flex flex-wrap items-center justify-center gap-4 lg:justify-start">
        <a
          href={menuHref}
          class="group relative overflow-hidden rounded-full border-2 border-primary bg-primary px-7 py-3 active:scale-95 duration-300  font-display  text-white  transition-transform   hover:bg-primary"
        >
          {menuLabel}
        </a>
        <a
          href={promoHref}
          class="rounded-full border-2 border-primary  font-display text-primary transition-colors px-7 py-3 active:scale-95 duration-300  hover:bg-primary hover:text-primary-text "
        >
          {promoLabel}
        </a>
      </div>
    </div>

    <!-- Columna de imagen -->
    <div class="relative flex-1 max-w-2xl md:mx-4 justify-center items-center max-h-100 lg:col-span-3 ">

        <img
          src={image}
          alt={imageAlt}
          class=" w-full  h-full md:rotate-90 lg:rotate-0 object-cover  "
        />


    </div>
  </div>
</section>

