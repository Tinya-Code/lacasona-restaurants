---

<section
  class="w-full px-4 py-16 sm:px-8 lg:px-16"
  aria-labelledby="gallery-heading"
>
  <header class="mx-auto mb-10 pt-10 max-w-3xl text-center">
    <h2
      id="gallery-heading"
      class=" font-display text-secondary text-6xl"
    >
      {config.heading}
      <span class="block h-1 w-16 mx-auto mt-3 rounded-full bg-primary"></span>
    </h2>
    {
      config.description && (
        <p class="mt-4  text-secondary ">{config.description}</p>
      )
    }
  </header>

  <!-- Grid estilo Pinterest -->
  <ul id="gallery-grid" class="pinterest-grid mx-auto max-w-7xl">
    {
      config.items.map((item) => (
        <li class="gallery-item pinterest-item" data-category={item.category}>
          <figure class="group relative m-0 overflow-hidden rounded-2xl bg-primary-text/5">
            <img
              src={item.src}
              alt={item.alt}
              loading="lazy"
              decoding="async"
              class="block w-full h-auto transition-transform duration-500 ease-out group-hover:scale-105"
            />
            <figcaption class="pointer-events-none absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-secondary/95 via-secondary/25 to-transparent p-4 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
              <span class="flex items-baseline justify-between gap-2">
                <span class="text-lg font-semibold text-primary-text">
                  {item.title}
                </span>
              </span>
            </figcaption>
          </figure>
        </li>
      ))
    }
  </ul>

  <p
    id="gallery-empty"
    class="hidden mx-auto mt-10 max-w-md text-center text-primary-text/60"
    role="status"
  >
    No hay elementos para esta categoría.
  </p>
</section>

<style>
  /*
    Grid tipo Pinterest.

    Base (soporte universal): CSS multi-column.
    Los <li> fluyen en columnas y se acomodan según su altura real,
    igual que Pinterest. Funciona en TODOS los navegadores hoy mismo.
  */
  .pinterest-grid {
    column-count: 2;
    column-gap: 1rem;
  }
  @media (min-width: 640px) {
    .pinterest-grid {
      column-count: 2;
    }
  }
  @media (min-width: 1024px) {
    .pinterest-grid {
      column-count: 3;
    }
  }
  @media (min-width: 1280px) {
    .pinterest-grid {
      column-count: 4;
    }
  }

  .pinterest-item {
    break-inside: avoid; /* evita que una tarjeta se corte entre columnas */
    -webkit-column-break-inside: avoid;
    margin-bottom: 1rem;
    display: inline-block;
    width: 100%;
  }

  /*
    Mejora progresiva: donde el navegador soporte CSS Grid Masonry
    nativo (grid-template-rows: masonry — Firefox estable, Safari
    en Technology Preview), lo activamos y se comporta igual pero
    con el motor de grid real en vez de columnas.
  */
  @supports (grid-template-rows: masonry) {
    .pinterest-grid {
      display: grid;
      grid-template-columns: repeat(1, 1fr);
      grid-template-rows: masonry;
      column-gap: 1rem;
      row-gap: 1rem;
    }
    @media (min-width: 640px) {
      .pinterest-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (min-width: 1024px) {
      .pinterest-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    @media (min-width: 1280px) {
      .pinterest-grid {
        grid-template-columns: repeat(4, 1fr);
      }
    }
    .pinterest-item {
      margin-bottom: 0; /* el row-gap del grid ya da el espacio */
    }
  }
</style>
