---
import { Icon } from "astro-icon/components";

interface Review {
  id: number;
  name: string;
  event: string;
  text: string;
  image: string;
  rating: number;
}

const { title, subtitle, reviews, cta } = Astro.props;

const avatarColors = [
  "bg-primary text-white",
  "bg-secondary text-white",
  "bg-accent text-white",
  "bg-primary/80 text-white",
];

const getInitials = (name: string) =>
  name
    .split(" ")
    .map((n) => n[0])
    .join("")
    .substring(0, 2)
    .toUpperCase();
---

<section
  id="testimonials"
  aria-labelledby="testimonials-heading"
  class="py-12 sm:py-16 md:py-20"
>
  <div class="container mx-auto px-4">
    <!-- Header -->
    <header class="mx-auto mb-12 max-w-3xl text-center">
      <div class="mb-3 flex items-center justify-center gap-2">
        <svg viewBox="0 0 24 24" width="20" height="20" class="h-4 w-4 sm:h-5 sm:w-5" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z"/>
        </svg>
        <span class="text-[11px] font-semibold uppercase tracking-wider text-secondary/60 sm:text-xs">
          Opiniones de Clientes
        </span>
      </div>
      <h2
        id="testimonials-heading"
        class="mb-3 font-display text-2xl font-bold text-secondary sm:mb-4 sm:text-3xl md:text-4xl"
      >
        {title}
      </h2>
      <p class="mx-auto max-w-xl font-body text-sm text-secondary/70 sm:text-base">
        {subtitle}
      </p>

      <!-- Rating summary -->
      <div class="mx-auto mt-5 flex w-fit flex-col items-center justify-center gap-2 rounded-2xl border border-secondary/10 px-4 py-2 sm:mt-6 sm:flex-row sm:gap-3 sm:rounded-full sm:px-6">
        <div class="flex items-center gap-0.5">
          <span class="mr-1 text-lg font-bold leading-none text-secondary sm:text-xl">4.9</span>
          {Array.from({ length: 5 }).map(() => (
            <Icon
              name="lucide:star"
              class="h-3.5 w-3.5 fill-accent text-accent sm:h-4 sm:w-4"
            />
          ))}
        </div>
        <span class="border-t border-secondary/10 pt-1.5 text-center text-[11px] font-medium text-secondary/60 sm:border-l sm:border-t-0 sm:pl-3 sm:pt-0">
          Calificación excelente en Google Maps (230+ reseñas)
        </span>
      </div>
    </header>

    <!-- Carousel with scroll-snap -->
    <div
      class="relative mx-auto max-w-7xl"
      role="region"
      aria-roledescription="carrusel"
      aria-label="Testimonios de clientes"
    >
      <!-- Scrollable track (visible window) -->
      <div
        id="testimonials-carousel-wrapper"
        class="scrollbar-none overflow-x-auto scroll-smooth snap-x snap-mandatory pb-4"
      >
        <ul
          id="testimonials-track"
          class="flex max-w-xs md:max-w-none gap-4"
          aria-live="polite"
        >
          {reviews.map((review, idx) => {
            const avatarColorClass = avatarColors[idx % avatarColors.length];
            const hasCustomImage =
              review.image && !review.image.includes("portada-fina-estampa");

            return (
              <li
                class="w-80 flex-shrink-0 snap-start"
                role="group"
                aria-roledescription="diapositiva"
                aria-label={`Testimonio ${idx + 1} de ${reviews.length}`}
              >
                <article
                  class="flex h-full flex-col rounded-2xl border border-secondary/10 bg-white p-4 shadow-[0_2px_6px_rgba(0,0,0,0.03)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_20px_rgba(0,0,0,0.06)] sm:p-6"
                >
                  <!-- Header: avatar, name, Google icon -->
                  <div class="mb-3 flex items-start justify-between gap-3 sm:mb-4">
                    <div class="flex items-center gap-2.5 sm:gap-3">
                      {hasCustomImage ? (
                        <div class="h-9 w-9 flex-shrink-0 overflow-hidden rounded-full border border-secondary/10 bg-secondary/10 sm:h-11 sm:w-11">
                          <img
                            src={review.image}
                            alt={`Foto de ${review.name}`}
                            class="h-full w-full object-cover"
                            loading="lazy"
                          />
                        </div>
                      ) : (
                        <div
                          class={`flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full font-display text-sm font-semibold sm:h-11 sm:w-11 sm:text-base ${avatarColorClass}`}
                        >
                          {getInitials(review.name)}
                        </div>
                      )}
                      <div>
                        <h3 class="font-display text-sm font-semibold leading-snug text-secondary">
                          {review.name}
                        </h3>
                        <div class="flex items-center gap-1">
                          <span class="text-[11px] font-medium text-secondary/60">
                            Local Guide
                          </span>
                          <span class="text-[10px] text-secondary/30">•</span>
                          <span class="text-[11px] text-secondary/60">
                            Verificado
                          </span>
                        </div>
                      </div>
                    </div>
                    <svg
                      viewBox="0 0 24 24"
                      width="16"
                      height="16"
                      class="mt-0.5 h-3.5 w-3.5 flex-shrink-0 opacity-80 sm:h-4 sm:w-4"
                      aria-hidden="true"
                    >
                      <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                      <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                      <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z"/>
                      <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z"/>
                    </svg>
                  </div>

                  <!-- Stars & relative date -->
                  <div class="mb-2.5 flex items-center gap-1.5 sm:mb-3">
                    <div class="flex gap-0.5">
                      {Array.from({ length: review.rating }).map(() => (
                        <Icon
                          name="lucide:star"
                          class="h-3 w-3 fill-accent text-accent sm:h-3.5 sm:w-3.5"
                        />
                      ))}
                    </div>
                    <span class="text-[11px] text-secondary/50">Hace 3 semanas</span>
                  </div>

                  <!-- Text -->
                  <blockquote class="mb-4 font-body text-sm leading-relaxed text-secondary/80">
                    “{review.text}”
                  </blockquote>

                  <!-- Footer -->
                  <footer class="mt-auto border-t border-secondary/10 pt-3">
                    <div class="flex flex-wrap items-center justify-between gap-2">
                      <span class="rounded bg-primary/5 px-2 py-0.5 text-[11px] font-semibold text-primary">
                        {review.event}
                      </span>
                      <span class="text-[11px] text-secondary/40">Google Maps</span>
                    </div>
                  </footer>
                </article>
              </li>
            );
          })}
        </ul>
      </div>

      <!-- Navigation buttons -->
      <button
        id="prev-testimonial"
        class="absolute left-2 top-1/2 z-20 flex h-8 w-8 -translate-y-1/2 items-center justify-center rounded-full border border-secondary/10 bg-white text-secondary/70 shadow transition-all duration-200 hover:scale-105 hover:text-primary focus:outline-none active:scale-95 disabled:pointer-events-none disabled:opacity-40 sm:h-10 sm:w-10"
        aria-label="Testimonio anterior"
      >
        <Icon name="lucide:chevron-left" class="h-4 w-4 sm:h-5 sm:w-5" />
      </button>
      <button
        id="next-testimonial"
        class="absolute right-2 top-1/2 z-20 flex h-8 w-8 -translate-y-1/2 items-center justify-center rounded-full border border-secondary/10 bg-white text-secondary/70 shadow transition-all duration-200 hover:scale-105 hover:text-primary focus:outline-none active:scale-95 disabled:pointer-events-none disabled:opacity-40 sm:h-10 sm:w-10"
        aria-label="Testimonio siguiente"
      >
        <Icon name="lucide:chevron-right" class="h-4 w-4 sm:h-5 sm:w-5" />
      </button>
    </div>

    <!-- Dots navigation -->
    <div
      id="testimonials-dots"
      class="mt-6 flex justify-center gap-1.5 sm:mt-8"
      role="tablist"
      aria-label="Navegación del carrusel"
    ></div>
  </div>
</section>

<style is:global>
  /* Ocultar la barra de scroll manteniendo funcionalidad */
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function initTestimonialsSlider() {
    const wrapper = document.getElementById('testimonials-carousel-wrapper') as HTMLElement;
    const track = document.getElementById('testimonials-track') as HTMLElement;
    const slides = track?.querySelectorAll('li');
    const prevBtn = document.getElementById('prev-testimonial') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-testimonial') as HTMLButtonElement;
    const dotsContainer = document.getElementById('testimonials-dots');

    if (!wrapper || !slides?.length || !prevBtn || !nextBtn || !dotsContainer) return;

    let currentIndex = 0;
    let autoplayInterval: number | null = null;
    const totalSlides = slides.length;

    // Desplazarse a una slide específica
    const scrollToSlide = (index: number) => {
      const slide = slides[index];
      if (!slide) return;
      const wrapperRect = wrapper.getBoundingClientRect();
      const slideRect = slide.getBoundingClientRect();
      const scrollLeft =
        wrapper.scrollLeft +
        slideRect.left -
        wrapperRect.left -
        (wrapperRect.width - slideRect.width) / 2;
      
      wrapper.scrollTo({
        left: Math.max(0, scrollLeft),
        behavior: 'smooth',
      });
    };

    // Actualizar índice actual basado en scroll
    const updateActiveIndex = () => {
      const wrapperRect = wrapper.getBoundingClientRect();
      const wrapperCenter = wrapperRect.left + wrapperRect.width / 2;
      
      let closestIndex = 0;
      let minDistance = Infinity;
      
      slides.forEach((slide, idx) => {
        const slideRect = slide.getBoundingClientRect();
        const slideCenter = slideRect.left + slideRect.width / 2;
        const distance = Math.abs(slideCenter - wrapperCenter);
        if (distance < minDistance) {
          minDistance = distance;
          closestIndex = idx;
        }
      });
      
      if (closestIndex !== currentIndex) {
        currentIndex = closestIndex;
        updateDots();
      }
    };

    // Reconstruir dots
    const updateDots = () => {
      dotsContainer.innerHTML = '';
      for (let i = 0; i < totalSlides; i++) {
        const dot = document.createElement('button');
        dot.className = `h-2 rounded-full transition-all duration-300 focus:outline-none ${
          i === currentIndex
            ? 'w-4 bg-primary'
            : 'w-2 bg-secondary/20 hover:bg-secondary/40'
        }`;
        dot.setAttribute('role', 'tab');
        dot.setAttribute('aria-label', `Ir al testimonio ${i + 1}`);
        dot.setAttribute('aria-selected', (i === currentIndex).toString());
        dot.onclick = () => {
          stopAutoplay();
          currentIndex = i;
          scrollToSlide(i);
          startAutoplay();
        };
        dotsContainer.appendChild(dot);
      }
      
      // Actualizar estado de botones
      prevBtn.disabled = currentIndex === 0;
      nextBtn.disabled = currentIndex >= totalSlides - 1;
    };

    const startAutoplay = () => {
      stopAutoplay();
      autoplayInterval = window.setInterval(() => {
        if (currentIndex < totalSlides - 1) {
          currentIndex++;
        } else {
          currentIndex = 0;
        }
        scrollToSlide(currentIndex);
        updateDots();
      }, 4000);
    };

    const stopAutoplay = () => {
      if (autoplayInterval) {
        clearInterval(autoplayInterval);
        autoplayInterval = null;
      }
    };

    const navigate = (delta: number) => {
      stopAutoplay();
      currentIndex = Math.max(0, Math.min(totalSlides - 1, currentIndex + delta));
      scrollToSlide(currentIndex);
      updateDots();
      startAutoplay();
    };

    prevBtn.onclick = () => navigate(-1);
    nextBtn.onclick = () => navigate(1);

    // Detectar scroll manual para sincronizar dots
    wrapper.addEventListener('scroll', () => {
      updateActiveIndex();
    }, { passive: true });

    // Pausar autoplay al interactuar con el carrusel
    wrapper.addEventListener('mouseenter', stopAutoplay);
    wrapper.addEventListener('mouseleave', startAutoplay);
    
    // Inicializar
    scrollToSlide(0);
    updateDots();
    startAutoplay();
  }

  document.addEventListener('astro:page-load', initTestimonialsSlider);
  initTestimonialsSlider();
</script>