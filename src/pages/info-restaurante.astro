---
import LayoutAstroComponent from "../layouts/Layout.astro";
import HeaderAstroComponent from "../shared/sections/Header.astro";
import { TemplateFooter } from "../menu-angular/base-template/components/footer/footer";
import { WhatsAppButton } from "../menu-angular/components/whatsapp-button/whatsapp-button.component";
import MainContentAstroComponent from "../shared/components/mainContent.astro";
import GalleryAstroComponent from "../shared/sections/gallery.astro";
---

<LayoutAstroComponent
    title="Info Restaurante"
    description="Información sobre el restaurante La Casona Manchay."
    keywords="info, restaurante, información"
    ogType="restaurant.restaurant"
    canonicalUrl="/info-restaurante"
>
    <HeaderAstroComponent />
    <MainContentAstroComponent>
        <GalleryAstroComponent/>
    
</MainContentAstroComponent>
    <TemplateFooter client:visible/>
    <WhatsAppButton client:visible/>
</LayoutAstroComponent>
